# Optional - only if you want to use API fallback
# IMPORTANT: replace the placeholder values below with your real keys in your local environment
# Do NOT commit real keys to the repository. Use a CI/Secrets manager or local .env file instead.
HF_API_KEY=REPLACE_WITH_YOUR_HF_API_KEY
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
# config
CHUNK_SIZE=300
TOP_K=3
LOCAL_GENERATOR_MODEL=google/flan-t5-base
USE_LOCAL_GENERATOR=true